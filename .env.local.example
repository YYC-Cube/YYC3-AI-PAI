# ============================================================================
# YYC3-AI-PAI 环境变量配置示例（完整版）
# ============================================================================
# 
# 文件说明：
# - 此文件为环境变量示例文件，请复制为 .env.local 使用
# - 所有敏感信息（API密钥等）建议在UI页面配置，而非硬编码在此文件
# - 此文件主要用于开发环境配置和测试
#
# 使用方法：
# 1. 复制此文件为 .env.local
# 2. 根据实际情况修改配置项
# 3. 敏感信息建议通过UI页面配置（推荐）
#
# 注意事项：
# - .env.local 文件不会被Git跟踪（已在.gitignore中配置）
# - 生产环境请使用环境变量注入或密钥管理服务
# - 所有API密钥都可以在应用设置页面动态配置
# ============================================================================

# ============================================================================
# 项目基础配置
# ============================================================================

# 应用名称
VITE_APP_NAME=YYC3-AI-PAI

# 应用版本
VITE_APP_VERSION=1.0.0

# 应用环境 (development | staging | production)
VITE_APP_ENV=development

# 应用端口
VITE_APP_PORT=3100

# 应用主机
VITE_APP_HOST=localhost

# 是否启用HTTPS
VITE_APP_HTTPS=false

# ============================================================================
# AI模型供应商配置
# ============================================================================
# 
# 重要说明：
# - 所有API密钥都可以在应用设置页面动态配置（推荐）
# - 此处配置仅用于开发测试环境
# - 生产环境请使用密钥管理服务
# ============================================================================

# ----------------------------------------------------------------------------
# OpenAI 配置
# ----------------------------------------------------------------------------
# API密钥（可在UI页面配置）
VITE_OPENAI_API_KEY=

# API基础URL（可选，用于代理或自定义端点）
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# 默认模型
VITE_OPENAI_DEFAULT_MODEL=gpt-4o

# 最大Token数
VITE_OPENAI_MAX_TOKENS=4096

# 温度参数
VITE_OPENAI_TEMPERATURE=0.7

# ----------------------------------------------------------------------------
# 智谱AI (ZhipuAI) 配置
# ----------------------------------------------------------------------------
# API密钥（可在UI页面配置）
VITE_ZHIPU_API_KEY=

# API基础URL
VITE_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 默认模型
VITE_ZHIPU_DEFAULT_MODEL=glm-5

# 最大Token数
VITE_ZHIPU_MAX_TOKENS=4096

# 温度参数
VITE_ZHIPU_TEMPERATURE=0.7

# ----------------------------------------------------------------------------
# 通义千问 (Qwen) 配置
# ----------------------------------------------------------------------------
# API密钥（可在UI页面配置）
VITE_QWEN_API_KEY=

# API基础URL
VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认模型
VITE_QWEN_DEFAULT_MODEL=qwen3-max

# 最大Token数
VITE_QWEN_MAX_TOKENS=4096

# 温度参数
VITE_QWEN_TEMPERATURE=0.7

# ----------------------------------------------------------------------------
# DeepSeek 配置
# ----------------------------------------------------------------------------
# API密钥（可在UI页面配置）
VITE_DEEPSEEK_API_KEY=

# API基础URL
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 默认模型
VITE_DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# 最大Token数
VITE_DEEPSEEK_MAX_TOKENS=4096

# 温度参数
VITE_DEEPSEEK_TEMPERATURE=0.7

# ----------------------------------------------------------------------------
# Ollama 本地模型配置
# ----------------------------------------------------------------------------
# Ollama服务地址
VITE_OLLAMA_BASE_URL=http://localhost:11434

# 默认模型
VITE_OLLAMA_DEFAULT_MODEL=llama3.1:8b

# 是否自动检测
VITE_OLLAMA_AUTO_DETECT=true

# 检测超时时间（毫秒）
VITE_OLLAMA_DETECT_TIMEOUT=5000

# ============================================================================
# 存储配置
# ============================================================================

# ----------------------------------------------------------------------------
# IndexedDB 配置
# ----------------------------------------------------------------------------
# 数据库名称
VITE_INDEXEDDB_NAME=yyc3-ai-pai-db

# 数据库版本
VITE_INDEXEDDB_VERSION=3

# 最大缓存大小（字节）
VITE_INDEXEDDB_MAX_CACHE_SIZE=524288000

# ----------------------------------------------------------------------------
# localStorage 配置
# ----------------------------------------------------------------------------
# 存储键前缀
VITE_LOCALSTORAGE_PREFIX=yyc3_

# 最大存储大小（字节）
VITE_LOCALSTORAGE_MAX_SIZE=5242880

# ----------------------------------------------------------------------------
# 文件存储配置
# ----------------------------------------------------------------------------
# 文件存储路径
VITE_FILE_STORAGE_PATH=./data/files

# 最大文件大小（字节）
VITE_MAX_FILE_SIZE=10485760

# 允许的文件类型
VITE_ALLOWED_FILE_TYPES=.ts,.tsx,.js,.jsx,.json,.md,.txt,.css,.html

# ----------------------------------------------------------------------------
# 缓存配置
# ----------------------------------------------------------------------------
# 缓存TTL（毫秒）
VITE_CACHE_TTL=300000

# 缓存最大数量
VITE_CACHE_MAX_SIZE=100

# 是否启用请求缓存
VITE_ENABLE_REQUEST_CACHE=true

# 是否启用LRU缓存
VITE_ENABLE_LRU_CACHE=true

# ============================================================================
# 加密与安全配置
# ============================================================================

# ----------------------------------------------------------------------------
# 加密配置
# ----------------------------------------------------------------------------
# 加密算法
VITE_ENCRYPTION_ALGORITHM=AES-GCM-256

# 加密强度 (standard | high)
VITE_ENCRYPTION_STRENGTH=standard

# PBKDF2迭代次数
VITE_PBKDF2_ITERATIONS=100000

# 自动锁定超时（分钟）
VITE_AUTO_LOCK_TIMEOUT=30

# ----------------------------------------------------------------------------
# CSRF保护配置
# ----------------------------------------------------------------------------
# 是否启用CSRF保护
VITE_ENABLE_CSRF_PROTECTION=true

# CSRF令牌长度
VITE_CSRF_TOKEN_LENGTH=32

# CSRF令牌过期时间（毫秒）
VITE_CSRF_TOKEN_EXPIRY=3600000

# ----------------------------------------------------------------------------
# CSP配置
# ----------------------------------------------------------------------------
# 是否启用CSP
VITE_ENABLE_CSP=true

# ============================================================================
# 性能监控配置
# ============================================================================

# ----------------------------------------------------------------------------
# 基础监控配置
# ----------------------------------------------------------------------------
# 是否启用性能监控
VITE_ENABLE_PERFORMANCE_MONITORING=true

# 是否启用Web Vitals监控
VITE_ENABLE_WEB_VITALS=true

# 是否启用系统监控
VITE_ENABLE_SYSTEM_MONITORING=true

# 是否启用内存监控
VITE_ENABLE_MEMORY_MONITORING=true

# 是否启用FPS监控
VITE_ENABLE_FPS_MONITORING=true

# 采样间隔（毫秒）
VITE_SAMPLE_INTERVAL=2000

# 是否启用调试模式
VITE_DEBUG_MODE=false

# ----------------------------------------------------------------------------
# 性能阈值配置
# ----------------------------------------------------------------------------
# FCP阈值（毫秒）
VITE_FCP_THRESHOLD=2000

# LCP阈值（毫秒）
VITE_LCP_THRESHOLD=2500

# FID阈值（毫秒）
VITE_FID_THRESHOLD=100

# CLS阈值
VITE_CLS_THRESHOLD=0.1

# CPU使用率阈值（%）
VITE_CPU_USAGE_THRESHOLD=30

# 内存使用阈值（MB）
VITE_MEMORY_USAGE_THRESHOLD=500

# ============================================================================
# 日志配置
# ============================================================================

# ----------------------------------------------------------------------------
# 基础日志配置
# ----------------------------------------------------------------------------
# 日志级别 (debug | info | warn | error)
VITE_LOG_LEVEL=info

# 是否启用控制台日志
VITE_ENABLE_CONSOLE_LOG=true

# 是否启用文件日志
VITE_ENABLE_FILE_LOG=false

# 日志文件路径
VITE_LOG_FILE_PATH=./logs/app.log

# 日志文件最大大小（字节）
VITE_LOG_FILE_MAX_SIZE=10485760

# 日志文件最大数量
VITE_LOG_FILE_MAX_COUNT=5

# ----------------------------------------------------------------------------
# 日志格式配置
# ----------------------------------------------------------------------------
# 日志时间格式
VITE_LOG_TIME_FORMAT=YYYY-MM-DD HH:mm:ss.SSS

# 是否显示源码位置
VITE_LOG_SHOW_SOURCE=true

# 是否显示堆栈信息
VITE_LOG_SHOW_STACK=true

# ============================================================================
# 开发配置
# ============================================================================

# ----------------------------------------------------------------------------
# 构建配置
# ----------------------------------------------------------------------------
# 是否启用HMR
VITE_ENABLE_HMR=true

# 是否启用Source Map
VITE_ENABLE_SOURCE_MAP=true

# 是否启用类型检查
VITE_ENABLE_TYPE_CHECK=true

# 是否启用ESLint
VITE_ENABLE_ESLINT=true

# ----------------------------------------------------------------------------
# 开发工具配置
# ----------------------------------------------------------------------------
# 是否启用React DevTools
VITE_ENABLE_REACT_DEVTOOLS=true

# 是否启用Redux DevTools
VITE_ENABLE_REDUX_DEVTOOLS=true

# 是否启用Zustand DevTools
VITE_ENABLE_ZUSTAND_DEVTOOLS=true

# 是否启用详细错误信息
VITE_ENABLE_VERBOSE_ERRORS=true

# ============================================================================
# 协作配置
# ============================================================================

# ----------------------------------------------------------------------------
# WebSocket配置
# ----------------------------------------------------------------------------
# WebSocket服务器地址
VITE_WEBSOCKET_URL=ws://localhost:8080

# 是否自动重连
VITE_WEBSOCKET_RECONNECT=true

# 重连间隔（毫秒）
VITE_WEBSOCKET_RECONNECT_INTERVAL=5000

# 最大重连次数
VITE_WEBSOCKET_MAX_RECONNECT_ATTEMPTS=5

# ----------------------------------------------------------------------------
# CRDT配置
# ----------------------------------------------------------------------------
# 是否启用CRDT协作
VITE_ENABLE_CRDT_COLLAB=true

# CRDT同步间隔（毫秒）
VITE_CRDT_SYNC_INTERVAL=1000

# CRDT最大历史记录数
VITE_CRDT_MAX_HISTORY=100

# ============================================================================
# MCP配置
# ============================================================================

# 是否启用MCP
VITE_ENABLE_MCP=true

# 是否自动运行MCP
VITE_MCP_AUTO_RUN=false

# ============================================================================
# 功能开关
# ============================================================================

# 是否启用AI补全
VITE_ENABLE_AI_COMPLETION=true

# 是否启用智能工作流
VITE_ENABLE_INTELLIGENT_WORKFLOW=true

# 是否启用实时预览
VITE_ENABLE_LIVE_PREVIEW=true

# 是否启用代码诊断
VITE_ENABLE_CODE_DIAGNOSTICS=true

# 是否启用文件同步
VITE_ENABLE_FILE_SYNC=true

# 是否启用版本控制
VITE_ENABLE_VERSION_CONTROL=true

# 是否启用自动保存
VITE_ENABLE_AUTO_SAVE=true

# 自动保存间隔（毫秒）
VITE_AUTO_SAVE_INTERVAL=30000

# ============================================================================
# UI配置
# ============================================================================

# ----------------------------------------------------------------------------
# 主题配置
# ----------------------------------------------------------------------------
# 默认主题 (cyberpunk | clean)
VITE_DEFAULT_THEME=cyberpunk

# 是否启用主题切换
VITE_ENABLE_THEME_SWITCH=true

# 是否启用动画
VITE_ENABLE_ANIMATIONS=true

# 动画持续时间（毫秒）
VITE_ANIMATION_DURATION=300

# ----------------------------------------------------------------------------
# 布局配置
# ----------------------------------------------------------------------------
# 默认布局模式 (ide | simple)
VITE_DEFAULT_LAYOUT_MODE=ide

# 是否启用面板拖拽
VITE_ENABLE_PANEL_DRAG=true

# 是否启用面板分割
VITE_ENABLE_PANEL_SPLIT=true

# ----------------------------------------------------------------------------
# 编辑器配置
# ----------------------------------------------------------------------------
# 默认字体大小
VITE_DEFAULT_FONT_SIZE=14

# 默认字体
VITE_DEFAULT_FONT_FAMILY=JetBrains Mono, Fira Code, monospace

# ============================================================================
# 国际化配置
# ============================================================================

# 默认语言
VITE_DEFAULT_LANGUAGE=zh-CN

# 支持的语言
VITE_SUPPORTED_LANGUAGES=zh-CN,en-US

# 是否启用语言切换
VITE_ENABLE_LANGUAGE_SWITCH=true

# ============================================================================
# 其他配置
# ============================================================================

# 应用标题
VITE_APP_TITLE=YYC3 AI Code - 多联式低码编程实时预览系统

# 应用描述
VITE_APP_DESCRIPTION=YYC3 AI Code - 多联式低码编程实时预览系统，支持AI辅助编程、实时协作、智能工作流

# 应用关键词
VITE_APP_KEYWORDS=AI,Code,Programming,Low-Code,Real-time Preview

# 应用作者
VITE_APP_AUTHOR=YanYuCloudCube Team

# 应用邮箱
VITE_APP_EMAIL=admin@0379.email

# 应用网站
VITE_APP_WEBSITE=https://github.com/YYC3/

# 应用许可证
VITE_APP_LICENSE=MIT

# 应用版权
VITE_APP_COPYRIGHT=© 2026 YanYuCloudCube Team. All rights reserved.
